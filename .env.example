# ============================================================
# FINDLEAKS — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# --- Auth ---
SECRET_KEY=change-me-to-a-long-random-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2b$12$changeme_bcrypt_hash_here

# --- Database (Supabase PostgreSQL) ---
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# --- Twitter/X API v2 ---
TWITTER_BEARER_TOKEN=AAAA_your_twitter_bearer_token_here

# --- Telegram Bot API ---
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFyour_telegram_bot_token_here

# --- SMTP (Email Alerts) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@yourdomain.com
SMTP_PASS=your_app_password_here

# --- SMS (Optional — Twilio) ---
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=your_twilio_auth_token
TWILIO_NUMBER=+15551234567

# --- App Settings ---
APP_NAME=FINDLEAKS
FAISS_INDEX_DIR=./indexes
UPLOAD_DIR=./uploads
ALERT_THRESHOLD_HIGH=0.80
ALERT_THRESHOLD_REVIEW=0.60
SCAN_DEDUP_MINUTES=30
LOG_LEVEL=INFO

# --- CORS / URLs ---
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# --- Railway (set automatically in Railway environment) ---
# PORT is injected by Railway — do not set manually
